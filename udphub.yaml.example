# DraARL 配置文件模板
# 复制此文件为 udphub.yaml 并根据实际情况修改配置

# 系统配置
System:
    Host: ""                   # 监听地址，空则监听所有网卡
    Port: "60050"              # UDP服务端口
    LogPath: ""                # 日志文件路径，空则不输出文件
    IPfile: ./udphub.ipdb      # IP数据库文件路径
    ProxyProtocol: ""          # PROXY Protocol 版本: "v2" 启用, 留空禁用。启用后可从 frp 等代理获取真实客户端 IP

# MySQL数据库配置
Database:
    Host: "127.0.0.1"
    Port: 3306
    User: "draarl"
    Password: "your_password_here"
    DBName: "draarl"
    Charset: "utf8mb4"
    Collate: "utf8mb4_unicode_ci"

    # 连接池配置
    MaxOpenConns: 25           # 最大打开连接数
    MaxIdleConns: 5            # 最大空闲连接数
    MaxLifetime: 300           # 连接最大存活时间(秒)

# Redis 配置（refresh token 优先使用 Redis；不可用时自动降级到内存存储）
Redis:
    Host: "127.0.0.1"
    Port: 6379
    Password: ""
    DB: 0
    Prefix: "draarl"
    DialTimeoutSec: 3
    ReadTimeoutSec: 2
    WriteTimeoutSec: 2
    PoolSize: 20

# Web服务配置
Web:
    Host: ""                   # 监听地址，空则监听所有网卡
    Port: "9000"               # Web服务端口
    FrontendURL: "http://localhost:5173"  # 前端地址，用于SSO回调后重定向
    AllowedOrigins:            # CORS / WS Origin 白名单：填写真正发起 API/WS 请求的页面域名
        - "http://localhost:5173"
    FrontendCDN:
        Enabled: false         # 开启后，启动时会将嵌入的前端静态资源同步到 MinIO
        ObjectPrefix: "frontend" # MinIO 中的前端资源根目录，实际会按版本写入如 frontend/v1.2.3/assets、frontend/v1.2.3/docs

# Keycloak SSO 单点登录配置 (可选)
Keycloak:
    Enabled: false                    # 是否启用SSO登录
    Name: "企业SSO"                    # SSO显示名称，用于登录按钮和绑定提示
    BaseURL: "http://localhost:8080"   # Keycloak服务器地址
    Realm: "draarl"                  # Realm名称
    ClientID: "draarl-frontend"      # 客户端ID
    ClientSecret: ""                  # 客户端密钥(如需要)
    RedirectURI: "http://localhost:9000/api/sso/callback"  # 回调地址（后端API）

# MinIO 对象存储配置 (可选)
MinIO:
    Endpoint: "localhost:9000"        # MinIO服务地址
    AccessKey: "minioadmin"           # Access Key
    SecretKey: "minioadmin"           # Secret Key
    UseSSL: false                     # 是否使用HTTPS
    Bucket: "draarl"                 # 默认存储桶
    BasePath: "/minio"                # URL访问基础路径

# 设备认证配置
DeviceAuth:
    AESKey: ""                        # AES 加密密钥，用于设备密码加密存储
                                      # 必须为 16、24 或 32 字节（对应 AES-128/192/256）
                                      # 留空则自动生成 32 字节密钥并写入配置文件
